# If DATABASE_URL is set, Moviejet stores posts in Postgres and ignores DATA_DIR.
# Without DATABASE_URL, Moviejet falls back to the local JSON file store.
DATABASE_URL=""
DATA_DIR="./data"
ADMIN_EMAIL="admin@moviejet.org"
ADMIN_PASSWORD="change-this-before-deploying"
ADMIN_PASSWORD_HASH=""
SESSION_SECRET="replace-this-with-a-long-random-secret"
